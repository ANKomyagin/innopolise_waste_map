# Production Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://waste_user:waste_password@postgres:5432/waste_db
POSTGRES_DB=waste_db
POSTGRES_USER=waste_user
POSTGRES_PASSWORD=waste_password

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_IDS=Мэрия=chat_id_municipality,Подрядчик=chat_id_contractor

# VK Configuration (Optional)
VK_TOKEN=your_vk_token_here

# Application Settings
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your_secret_key_here_generate_random_string

# Server Configuration
HOST=0.0.0.0
PORT=8000
PUBLIC_SERVER_URL=http://194.67.122.226:8000

# Yandex Maps API
YANDEX_API_KEY=7d253372-5194-4f00-a292-ea1d7bc18844

# Geospatial Settings (Innopolis coordinates)
DEFAULT_LAT=55.753
DEFAULT_LON=48.743
DEFAULT_ZOOM=13

# Thresholds
FILL_THRESHOLD_HIGH=70
FILL_THRESHOLD_MEDIUM=50
ANTI_SPAM_SECONDS=300

# CORS Settings
ALLOWED_ORIGINS=http://194.67.122.226,https://your-domain.com

# Logging
LOG_LEVEL=INFO

# Monitoring
ENABLE_METRICS=true
