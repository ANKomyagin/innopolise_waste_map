# ============================================================================
# Innopolis Smart Waste Management System - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file to Git (it's in .gitignore)

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://waste_user:waste_password@postgres:5432/waste_db

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=waste_db
POSTGRES_USER=waste_user
POSTGRES_PASSWORD=waste_password

# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Chat IDs for different roles (comma-separated)
# Format: Role=chat_id,Role2=chat_id2
# Get chat IDs by sending /start to your bot and checking logs
TELEGRAM_CHAT_IDS=Мэрия=chat_id_municipality,Подрядчик=chat_id_contractor

# ============================================================================
# VK CONFIGURATION (Optional)
# ============================================================================
# VK API token for VK notifications (leave empty if not using)
VK_TOKEN=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=production

# Debug mode (true/false) - NEVER enable in production!
DEBUG=false

# Secret key for sessions/tokens (generate random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_generate_random_string

# ============================================================================
# SECURITY
# ============================================================================
# JWT Authentication (NEW - replaces API key)
# Admin credentials (Мэрия)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Contractor credentials (Водитель мусоровоза)
CONTRACTOR_USERNAME=driver
CONTRACTOR_PASSWORD=driver123

# DEPRECATED: Old API key authentication (will be removed)
# API key for admin endpoints (POST/PUT/DELETE operations)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Use this in X-API-Key header when calling admin endpoints
ADMIN_API_KEY=your_secure_admin_api_key_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Host to bind to (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Port for FastAPI application
PORT=8000

# Public URL for webhooks and notifications
# Update this with your actual server IP or domain
PUBLIC_SERVER_URL=http://your-server-ip:8000

# ============================================================================
# GEOSPATIAL SETTINGS
# ============================================================================
# Default map center coordinates (Innopolis by default)
DEFAULT_LAT=55.753
DEFAULT_LON=48.743
DEFAULT_ZOOM=13

# ============================================================================
# THRESHOLDS & ALERTS
# ============================================================================
# Container fill percentage thresholds for alerts
FILL_THRESHOLD_HIGH=70
FILL_THRESHOLD_MEDIUM=50

# Anti-spam protection (seconds between reports from same device)
ANTI_SPAM_SECONDS=300

# ============================================================================
# CORS SETTINGS
# ============================================================================
# Allowed origins for CORS (comma-separated)
# Use * for development, specific domains for production
ALLOWED_ORIGINS=http://localhost:8000,http://your-domain.com

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# MONITORING (Optional)
# ============================================================================
# Enable metrics collection
ENABLE_METRICS=true
