# Production Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://waste_user:waste_password@postgres:5432/waste_db
POSTGRES_DB=waste_db
POSTGRES_USER=waste_user
POSTGRES_PASSWORD=waste_password

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# VK Configuration (Optional)
VK_TOKEN=your_vk_token_here

# Application Settings
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your_secret_key_here_generate_random_string

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (if needed)
ALLOWED_ORIGINS=http://194.67.122.226,https://your-domain.com

# Logging
LOG_LEVEL=INFO

# Monitoring
ENABLE_METRICS=true
